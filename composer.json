{
    "name": "joranski/agents",
    "description": "AI agent skills, smart deploy (git:pull), safe push (git:push), and Night Shift automation for Laravel projects.",
    "keywords": ["laravel", "agents", "deploy", "git", "ai", "filament", "skills"],
    "license": "MIT",
    "authors": [
        {
            "name": "James Oranski",
            "email": "joranski@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/console": "^12.0 || ^13.0",
        "illuminate/support": "^12.0 || ^13.0",
        "illuminate/process": "^12.0 || ^13.0",
        "laravel/prompts": "^0.1 || ^0.2 || ^0.3",
        "laravel/boost": "^2.0",
        "laravel/mcp": "^0.1",
        "laravel/pint": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "Joranski\\Agents\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Joranski\\Agents\\AgentsServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
